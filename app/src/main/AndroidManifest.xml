<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Core alarm/wakeup permissions -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Exact-alarm permissions: SCHEDULE_EXACT_ALARM is required on API
         31-32; from API 33 we use USE_EXACT_ALARM (auto-granted for
         alarm-clock apps under Play policy). -->
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Foreground service for the ringtone playback. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Full-screen intent to surface the dismiss UI over the lockscreen. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Notification permission required from API 33. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".AlarmXApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Mytest">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Mytest">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service that plays the alarm ringtone and holds the
             WakeLock. mediaPlayback is the closest fit for alarm audio
             playback under API 34+ foregroundServiceType requirements. -->
        <service
            android:name=".system.alarm.AlarmRingtoneService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Receives the PendingIntent fired by AlarmManager. -->
        <receiver
            android:name=".system.alarm.AlarmBroadcastReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.mytest.action.ALARM_FIRED" />
            </intent-filter>
        </receiver>

        <!-- Re-arms enabled alarms on reboot / app upgrade / time-zone change. -->
        <receiver
            android:name=".system.boot.BootCompletedReceiver"
            android:exported="true"
            tools:ignore="ExportedReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
